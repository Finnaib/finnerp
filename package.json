{
  "name": "finn-erp",
  "version": "1.0.0",
  "author": "Finn ERP",
  "description": "Professional POS and ERP System",
  "homepage": ".",
  "private": true,
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.6.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.263.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "main": "build/electron.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "set CI=false&& react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron public/electron.js\"",
    "electron-build": "npm run build && electron-builder",
    "electron-build:msi": "npm run build && electron-builder --win msi"
  },
  "build": {
    "appId": "com.finn.erp",
    "productName": "Finn ERP - POS",
    "extends": null,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "nsis",
        "msi"
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "wait-on": "^9.0.4"
  }
}
